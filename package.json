{
  "name": "draftlet",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "typecheck": "pnpm --filter @draftlet/shared typecheck && pnpm --dir apps/extension exec tsc --noEmit && pnpm --dir apps/desktop typecheck",
    "dev": "./scripts/dev.sh",
    "dev:desktop": "./scripts/dev-desktop.sh",
    "dev:extension": "./scripts/dev-extension.sh",
    "dev:server": "./scripts/dev-server.sh",
    "build": "./scripts/build.sh"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.1.3",
      "onFail": "download"
    }
  }
}
